NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/syllab
REDIS_URL=redis://localhost:6379

JWT_SECRET=REPLACE_ME_MIN_32_CHARS_GENERATE_WITH_CRYPTO
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=REPLACE_ME_DIFFERENT_MIN_32_CHARS_GENERATE
JWT_REFRESH_EXPIRES_IN=7d

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001
AUTH_RATE_LIMIT_PER_MIN=5

SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_mailtrap_username
SMTP_PASS=your_mailtrap_password
SMTP_FROM=noreply@syllab.io

APP_BASE_URL=http://localhost:3000
EMAIL_VERIFY_TTL_HOURS=24
PASSWORD_RESET_TTL_HOURS=1
WORKER_CONCURRENCY=5

SEED_ADMIN_EMAIL=admin@syllab.local
SEED_ADMIN_PASSWORD=AdminPass123!
