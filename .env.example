# Proveny — Environment Variables (local + DeployRocks)
# Copy to .env and fill in real values before running.

#   Runtime                  
NODE_ENV=development
ENVIRONMENT=development
PORT=3000
BACKEND_PORT=3000
FRONTEND_PORT=3001

#   Database & Cache               
# Local: postgresql://Proveny_user:password@localhost:5432/Proveny_db
# Docker Compose / DeployRocks: use service hostname "postgres"
DATABASE_URL=postgresql://Proveny_user:password@postgres:5432/Proveny_db

# Local: redis://localhost:6379
# Docker Compose / DeployRocks: use service hostname "redis"
REDIS_URL=redis://redis:6379

#   JWT (aliases for grading rubric)        
# JWT_SECRET_KEY and JWT_REFRESH_SECRET_KEY map to JWT_SECRET / JWT_REFRESH_SECRET
JWT_SECRET=REPLACE_ME_MIN_32_CHARS_GENERATE_WITH_CRYPTO
JWT_SECRET_KEY=REPLACE_ME_MIN_32_CHARS_GENERATE_WITH_CRYPTO
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=REPLACE_ME_DIFFERENT_MIN_32_CHARS_GENERATE
JWT_REFRESH_SECRET_KEY=REPLACE_ME_DIFFERENT_MIN_32_CHARS_GENERATE
JWT_REFRESH_EXPIRES_IN=7d

#   CORS                   
# Comma-separated origins. Include your DeployRocks domain in production.
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5173
CORS_ORIGINS=http://localhost:3001,http://localhost:5173

#   Rate Limiting                
AUTH_RATE_LIMIT_PER_MIN=20

#   Email (SMTP — Mailtrap, SendGrid SMTP, Brevo, etc.)   ─
EMAIL_API_KEY=your_smtp_password_or_api_key
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
EMAIL_FROM_ADDRESS=noreply@Proveny.io
SMTP_FROM=noreply@Proveny.io

# Public frontend URL (used in verification/reset email links)
APP_BASE_URL=http://localhost:3001
EMAIL_VERIFY_TTL_HOURS=24
PASSWORD_RESET_TTL_HOURS=1

#   Workers 
WORKER_CONCURRENCY=5

#   Seed Admin (first boot only)           
SEED_ADMIN_EMAIL=admin@Proveny.local
SEED_ADMIN_PASSWORD=AdminPass123!
